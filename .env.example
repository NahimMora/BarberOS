# ──────────────────────────────────────────────
# Supabase → Project Settings → API
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Solo server-side. NUNCA exponer al cliente.
# Usar exclusivamente en scripts/seed.ts y admin tasks puntuales.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────

# Runtime (App Router, Server Actions, Route Handlers)
# Usar Transaction Pooler: Supabase → Project Settings → Database
#   → Connection Pooling → Transaction mode
# Puerto 6543 — requerido con PgBouncer en Vercel/serverless
DATABASE_URL=postgresql://postgres.<ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true

# Migraciones (drizzle-kit migrate)
# Usar Direct Connection: Supabase → Project Settings → Database → Direct Connection
# Puerto 5432 — Drizzle necesita DDL sin pooler
DIRECT_URL=postgresql://postgres.<ref>:<password>@<direct-host>:5432/postgres
